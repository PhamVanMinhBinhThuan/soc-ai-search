{
  "realm": "soc-ai-search",
  "loginTheme": "soc-ai-search",
  "enabled": true,
  "displayName": "SOC AI Search",
  "registrationAllowed": false,
  "registrationEmailAsUsername": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "verifyEmail": true,
  "requiredActions": [
    {
      "alias": "VERIFY_EMAIL",
      "name": "Verify Email",
      "providerId": "VERIFY_EMAIL",
      "enabled": true,
      "defaultAction": true,
      "priority": 50
    },
    {
      "alias": "UPDATE_PASSWORD",
      "name": "Update Password",
      "providerId": "UPDATE_PASSWORD",
      "enabled": true,
      "defaultAction": true,
      "priority": 40
    },
    {
      "alias": "UPDATE_PROFILE",
      "name": "Update Profile",
      "providerId": "UPDATE_PROFILE",
      "enabled": true,
      "defaultAction": false,
      "priority": 60
    },
    {
      "alias": "CONFIGURE_TOTP",
      "name": "Configure OTP",
      "providerId": "CONFIGURE_TOTP",
      "enabled": true,
      "defaultAction": false,
      "priority": 70
    },
    {
      "alias": "TERMS_AND_CONDITIONS",
      "name": "Terms and Conditions",
      "providerId": "TERMS_AND_CONDITIONS",
      "enabled": false,
      "defaultAction": false,
      "priority": 80
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "SOC_VIEWER",
        "description": "Read-only SOC demo user. Can view dashboard and basic search results."
      },
      {
        "name": "SOC_ANALYST",
        "description": "SOC analyst demo user. Can investigate events, view history, and export results."
      },
      {
        "name": "SOC_ADMIN",
        "description": "SOC admin demo user. Can review audit logs and manage users through Keycloak."
      }
    ]
  },
  "clients": [
    {
      "clientId": "soc-ai-search-frontend",
      "name": "SOC AI Search Frontend",
      "description": "React SPA client for SOC AI Search MVP.",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "frontchannelLogout": true,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:5173/*",
        "https://soc-ai-search.app/auth/callback",
        "https://soc-ai-search.app/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:5173",
        "https://soc-ai-search.app"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3000##http://localhost:3000/##http://localhost:3000/*##http://localhost:5173##http://localhost:5173/##http://localhost:5173/*##https://soc-ai-search.app##https://soc-ai-search.app/##https://soc-ai-search.app/*"
      }
    }
  ]
}
