{
  "realm": "soc-ai-search",
  "enabled": true,
  "displayName": "SOC AI Search",
  "registrationAllowed": false,
  "registrationEmailAsUsername": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "verifyEmail": true,
  "roles": {
    "realm": [
      {
        "name": "SOC_VIEWER",
        "description": "Read-only SOC demo user. Can view dashboard and basic search results."
      },
      {
        "name": "SOC_ANALYST",
        "description": "SOC analyst demo user. Can investigate events, view history, and export results."
      },
      {
        "name": "SOC_ADMIN",
        "description": "SOC admin demo user. Can review audit logs and manage users through Keycloak."
      }
    ]
  },
  "clients": [
    {
      "clientId": "soc-ai-search-frontend",
      "name": "SOC AI Search Frontend",
      "description": "React SPA client for SOC AI Search MVP.",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "frontchannelLogout": true,
      "redirectUris": [
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3000/*"
      }
    }
  ]
}
