<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>SOC AI Search - Account Activation</title>
</head>
<body style="margin: 0; padding: 0; background-color: #f4f5f7; font-family: 'Inter', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">
    <table border="0" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f4f5f7; padding: 40px 0;">
        <tr>
            <td align="center">
                <table border="0" cellpadding="0" cellspacing="0" width="600" style="background-color: #ffffff; border-radius: 8px; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05); overflow: hidden;">
                    <tr>
                        <td align="center" style="background-color: #0f172a; padding: 40px 0;">
                            <h1 style="color: #ffffff; margin: 0; font-size: 28px; letter-spacing: 2px;">SOC AI SEARCH</h1>
                            <p style="color: #94a3b8; margin: 10px 0 0 0; font-size: 14px; text-transform: uppercase; letter-spacing: 1px;">Security Operations Center</p>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 40px 50px;">
                            <h2 style="color: #1e293b; margin-top: 0; font-size: 22px;">Welcome Aboard!</h2>
                            <p style="color: #475569; font-size: 16px; line-height: 1.6; margin-bottom: 25px;">
                                Your administrator has created an account for you on <strong>SOC AI Search</strong>. 
                                To activate your account and set up your secure access, please click the button below:
                            </p>
                            
                            <table border="0" cellpadding="0" cellspacing="0" width="100%">
                                <tr>
                                    <td align="center" style="padding: 10px 0 30px 0;">
                                        <a href="${link}" style="display: inline-block; background-color: #3b82f6; color: #ffffff; font-weight: bold; font-size: 16px; text-decoration: none; padding: 14px 32px; border-radius: 6px; box-shadow: 0 4px 6px rgba(59, 130, 246, 0.25);">ACTIVATE ACCOUNT</a>
                                    </td>
                                </tr>
                            </table>

                            <p style="color: #64748b; font-size: 14px; line-height: 1.5; margin-bottom: 10px;">
                                <strong>Required actions:</strong> <span style="color: #ef4444;">Verify Email, Update Password</span>
                            </p>
                            <p style="color: #64748b; font-size: 14px; line-height: 1.5; margin-bottom: 0;">
                                <em>Note: For security reasons, this link will expire in 12 hours.</em>
                            </p>
                        </td>
                    </tr>
                    <tr>
                        <td align="center" style="background-color: #f8fafc; padding: 30px 50px; border-top: 1px solid #e2e8f0;">
                            <p style="color: #94a3b8; font-size: 12px; margin: 0; line-height: 1.5;">
                                If you did not expect this invitation, please ignore this email or contact your security administrator.
                            </p>
                            <p style="color: #94a3b8; font-size: 12px; margin: 10px 0 0 0;">
                                &copy; 2026 SOC AI Search. All rights reserved.
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
