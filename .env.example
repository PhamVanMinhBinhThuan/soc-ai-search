# Used when running PostgreSQL and backend locally.
# Docker Compose can override POSTGRES_HOST with the PostgreSQL service name.
POSTGRES_HOST=localhost
# Host port for pgAdmin Desktop or a backend process running outside Docker.
# The backend container still connects to postgres:5432 inside Docker Compose.
POSTGRES_PORT=5433
POSTGRES_DB=soc_ai_search
POSTGRES_USER=soc_ai_search
POSTGRES_PASSWORD=change-me
APP_DEMO_USER_IDENTITY=demo-analyst
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,https://soc-ai-search.app

BACKEND_PORT=8081
FRONTEND_PORT=3000
ELASTICSEARCH_PORT=9200
# Backend running outside Docker uses localhost. Docker Compose overrides
# ELASTICSEARCH_URL to http://elasticsearch:9200 inside the Compose network.
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_EVENTS=soc-events-v1
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
EXPORT_ES_TIMEOUT_MS=10000
KIBANA_PORT=5601

# Public HTTPS deployment domains used by docker-compose.deploy.yml + Caddy.
# Point these DNS A records to the VPS public IP before enabling the proxy
# profile. For local-only Docker Compose, leave them unchanged or unused.
APP_DOMAIN=soc-ai-search.app
API_DOMAIN=api.soc-ai-search.app
AUTH_DOMAIN=auth.soc-ai-search.app

# LLM settings for Day 4.
# Default uses mock provider, so the MVP can run without an external API key.
LLM_PROVIDER=mock
# To test Gemini manually, set LLM_PROVIDER=gemini and provide the values below.
# Gemini REST API base URL. GeminiLlmClient appends /models/{model}:generateContent.
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta
LLM_API_KEY=
LLM_MODEL=gemini-2.5-flash
LLM_TIMEOUT_MS=10000
LLM_SUMMARY_TIMEOUT_MS=5000
LLM_MAX_ATTEMPTS=2

# Keycloak auth foundation for Day 8.
# Local/test can keep auth disabled. Public demo should set APP_AUTH_ENABLED=true
# after backend/frontend auth integration is complete.
APP_AUTH_ENABLED=false
KEYCLOAK_PORT=8082
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak
KEYCLOAK_REALM=soc-ai-search
KEYCLOAK_FRONTEND_CLIENT_ID=soc-ai-search-frontend
KEYCLOAK_ISSUER_URI=http://localhost:8082/realms/soc-ai-search
# Docker backend should use the internal Keycloak service URL for JWKS.
KEYCLOAK_JWK_SET_URI=http://keycloak:8080/realms/soc-ai-search/protocol/openid-connect/certs

# Production/domain example:
# KEYCLOAK_ISSUER_URI=https://auth.soc-ai-search.app/realms/soc-ai-search
# KEYCLOAK_JWK_SET_URI=http://keycloak:8080/realms/soc-ai-search/protocol/openid-connect/certs

# ── Keycloak SMTP / Email onboarding ──────────────────────────────────
# Required for admin-created user email onboarding (verify email, update password).
# Without SMTP, admin must set temporary passwords manually in Keycloak Admin Console.
#
# ── Local/Dev with Mailtrap (sandbox - emails are captured, never sent to real inboxes) ──
# KEYCLOAK_SMTP_HOST=sandbox.smtp.mailtrap.io
# KEYCLOAK_SMTP_PORT=587
# KEYCLOAK_SMTP_FROM=no-reply@soc-ai-search.app
# KEYCLOAK_SMTP_FROM_DISPLAY_NAME=SOC AI Search
# KEYCLOAK_SMTP_USER=<your-mailtrap-username>
# KEYCLOAK_SMTP_PASSWORD=<your-mailtrap-password>
# KEYCLOAK_SMTP_AUTH=true
# KEYCLOAK_SMTP_STARTTLS=true
# KEYCLOAK_SMTP_SSL=false
#
# ── Production/Demo with Gmail App Password ──
# Create a Google App Password at https://myaccount.google.com/apppasswords
# Do NOT use your main Gmail password. Generate a dedicated app password.
# KEYCLOAK_SMTP_HOST=smtp.gmail.com
# KEYCLOAK_SMTP_PORT=587
# KEYCLOAK_SMTP_FROM=your-email@gmail.com
# KEYCLOAK_SMTP_FROM_DISPLAY_NAME=SOC AI Search
# KEYCLOAK_SMTP_USER=your-email@gmail.com
# KEYCLOAK_SMTP_PASSWORD=<your-gmail-app-password>
# KEYCLOAK_SMTP_AUTH=true
# KEYCLOAK_SMTP_STARTTLS=true
# KEYCLOAK_SMTP_SSL=false
KEYCLOAK_SMTP_HOST=
KEYCLOAK_SMTP_PORT=587
KEYCLOAK_SMTP_FROM=no-reply@soc-ai-search.app
KEYCLOAK_SMTP_FROM_DISPLAY_NAME=SOC AI Search
KEYCLOAK_SMTP_USER=
KEYCLOAK_SMTP_PASSWORD=
KEYCLOAK_SMTP_AUTH=true
KEYCLOAK_SMTP_STARTTLS=true
KEYCLOAK_SMTP_SSL=false

# Frontend Vite auth placeholders. These are consumed from frontend/.env when
# running Vite locally; keep them here as deployment reference.
VITE_AUTH_ENABLED=false
VITE_KEYCLOAK_AUTHORITY=http://localhost:8082/realms/soc-ai-search
VITE_KEYCLOAK_CLIENT_ID=soc-ai-search-frontend
VITE_KEYCLOAK_REDIRECT_URI=http://localhost:3000/auth/callback
VITE_KEYCLOAK_POST_LOGOUT_REDIRECT_URI=http://localhost:3000
VITE_KEYCLOAK_SCOPE=openid profile email

# Frontend production/domain example:
# VITE_API_BASE_URL=https://api.soc-ai-search.app
# VITE_AUTH_ENABLED=true
# VITE_KEYCLOAK_AUTHORITY=https://auth.soc-ai-search.app/realms/soc-ai-search
# VITE_KEYCLOAK_CLIENT_ID=soc-ai-search-frontend
# VITE_KEYCLOAK_ADMIN_URL=https://auth.soc-ai-search.app/admin/master/console/#/soc-ai-search
# VITE_KEYCLOAK_REDIRECT_URI=https://soc-ai-search.app/auth/callback
# VITE_KEYCLOAK_POST_LOGOUT_REDIRECT_URI=https://soc-ai-search.app
# VITE_KEYCLOAK_SCOPE=openid profile email
